# Server Environment Config
PORT=5000
NODE_ENV=development

# Development Local Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_local_postgres_password
DB_NAME=chat_db

# Production Database (Neon PostgreSQL Connection URL)
DATABASE_URL=postgresql://user:password@host-subdomain.neon.tech/dbname?sslmode=require

# JWT Token Secrets
JWT_ACCESS_SECRET=your_32_character_access_secret_key_here
JWT_REFRESH_SECRET=your_32_character_refresh_secret_key_here

# Production Frontend Allowed Origin
CLIENT_URL=https://your-frontend-web-app.netlify.app
